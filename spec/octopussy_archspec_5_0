from __future__ import annotations
from abc import ABC, abstractmethod
from typing import Any
from uuid import UUID

from octopussy.core.message import OctopussyMessage


class MessagingContract(ABC):
    """
    Provisions (interfaces this Capability provides to others):
    - publish: publish a message to the bus
    - subscribe: subscribe an agent's inQ to receive messages
    - unsubscribe: unsubscribe an agent from the message bus
    - get_dlq_messages: retrieve messages from the Dead Letter Queue
    - replay_dlq_message: replay a DLQ message
    - discard_dlq_message: permanently discard a DLQ entry
    - get_dlq_size: return the current number of DLQ entries

    Requirements (interfaces this Capability consumes, injected via inject_dependency()):
    - ConfigurationCapability → ConfigurationPort
    - SecurityCapability      → SecurityPort
    - ObservabilityCapability → ObservabilityPort

    Protocols:
    - Default transport: NATS.io pub/sub (nats://host:4222).
    - Optional transport: RabbitMQ AMQP 0-9-1 (amqp://host:5672 or amqps://host:5671 with TLS).
    - publish() routes message to recipient's inQ (asyncio.PriorityQueue).
    - Messages failing delivery after 3 attempts go to DLQ (never silently discarded).
    - DLQ entries are persisted in SQLite and survive system restarts.
    - DLQ messages can be replayed via CLI or REST API.
    - All messages are signature-verified (HMAC-SHA256) before routing.
    - All messages are priority-ordered: CRITICAL (0) routed first.

    Dead Letter Queue (DLQ) — Normative:
    Every message that cannot be delivered after 3 consecutive attempts is stored in the DLQ.
    No message is ever silently discarded. Every DLQ entry contains: the full original
    OctopussyMessage, the failure reason, the attempt count, and the timestamp of the last
    failure. DLQ entries are persisted in SQLite (dlq_store.py) and survive system restarts.
    DLQ entries can be inspected and replayed via:
      CLI:  octopussy task list --dlq
            octopussy task replay <dlq_entry_id>
            octopussy task discard <dlq_entry_id>
      REST: GET  /api/v1/dlq
            POST /api/v1/dlq/{dlq_entry_id}/replay
            DELETE /api/v1/dlq/{dlq_entry_id}
    """

    @abstractmethod
    async def publish(self, message: OctopussyMessage) -> None:
        """
        Publish a message to the bus.
        Raises MessageSignatureError if signature is invalid.
        After 3 failed delivery attempts, message is stored in DLQ.
        """
        ...

    @abstractmethod
    async def subscribe(self, agent_id: UUID, queue: Any) -> None:
        """Subscribe an agent's inQ (asyncio.PriorityQueue) to receive messages."""
        ...

    @abstractmethod
    async def unsubscribe(self, agent_id: UUID) -> None: ...

    @abstractmethod
    async def get_dlq_messages(self, limit: int = 100) -> list[dict]: ...

    @abstractmethod
    async def replay_dlq_message(self, dlq_entry_id: str) -> None: ...

    @abstractmethod
    async def discard_dlq_message(self, dlq_entry_id: str) -> None: ...

    @abstractmethod
    async def get_dlq_size(self) -> int: ...

    @abstractmethod
    async def inject_dependency(self) -> None:
        """CCA Lifecycle Phase 3: inject all required interface references."""
        ...


