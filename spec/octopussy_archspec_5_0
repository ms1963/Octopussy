import logging
from typing import Any

from octopussy.core.registry import OctopussyCapabilityRegistry

logger = logging.getLogger(__name__)


class CapabilityLifecycleError(Exception): ...


class OctopussyCapabilityLifecycleManager:
    """
    Orchestrates all Capability Instances through the mandatory six-phase CCA lifecycle:
    instantiate → initialize() → inject_dependency() → start()
    → [runtime] →
    stop() → cleanup()

    CCA 0.2 Role: Capability Lifecycle Manager
    - Computes topologically sorted startup order using Kahn's algorithm.
    - Enforces the six-phase lifecycle on every Capability Instance.
    - inject_dependency(): resolves all Requirement interfaces and injects them
      into each Capability. This is the exclusive DI mechanism.
    - Shuts down in strict reverse topological order.
    - Is itself a CCA element.
    """

    def __init__(self, registry: OctopussyCapabilityRegistry) -> None:
        self._registry = registry
        self._order:   list[str] = []

    async def start_all(self) -> None:
        """
        Start all Capability Instances in topological order.
        Each Capability goes through: initialize() → inject_dependency() → start()
        inject_dependency() resolves all interfaces declared as Requirements
        in the Capability's Contract and injects the concrete references
        into the Capability instance. This is the exclusive DI mechanism.
        Raises CapabilityLifecycleError if any phase fails.
        """
        self._order = self._registry.topological_order()
        logger.info(
            "Starting %d Capabilities in order: %s", len(self._order), self._order
        )

        for name in self._order:
            cap = self._registry.get(name)
            try:
                logger.info("Initializing Capability: %s", name)
                await cap.initialize()
                logger.info("Injecting dependencies for Capability: %s", name)
                await cap.inject_dependency()   # CCA Phase 3: inject all Requirements
                logger.info("Starting Capability: %s", name)
                await cap.start()
                logger.info("Capability started: %s", name)
            except Exception as exc:
                raise CapabilityLifecycleError(
                    f"Capability {name} failed during startup: {exc}"
                ) from exc

        logger.info("All %d Capabilities started successfully.", len(self._order))

    async def stop_all(self) -> None:
        """
        Stop all Capability Instances in strict reverse topological order.
        Each Capability goes through: stop() → cleanup()
        """
        for name in reversed(self._order):
            cap = self._registry.get(name)
            try:
                logger.info("Stopping Capability: %s", name)
                await cap.stop()
                logger.info("Cleaning up Capability: %s", name)
                await cap.cleanup()
                logger.info("Capability stopped: %s", name)
            except Exception as exc:
                logger.error("Capability %s failed during shutdown: %s", name, exc)

