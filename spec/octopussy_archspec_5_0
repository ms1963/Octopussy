from __future__ import annotations
from abc import ABC, abstractmethod


class UserAgentExtensionContract(ABC):
    """
    Provisions (interfaces this Capability provides to others):
    - register_agent_class: register a user-defined OctopussyAgent subclass
    - resolve_agent_class: resolve a registered agent class by agent_type string
    - unregister_agent_class: unregister a user-defined agent class
