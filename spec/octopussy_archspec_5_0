from __future__ import annotations
from abc import ABC, abstractmethod
from uuid import UUID

from octopussy.core.message import OctopussyMessage


class ActorContract(ABC):
    """
    Provisions (interfaces this Capability provides to others):
    - enqueue: enqueue an inbound message into inQ (asyncio.PriorityQueue)
    - pause: pause message processing
    - resume: resume message processing
    - stop: initiate graceful shutdown

    Requirements (interfaces this Capability consumes, injected via inject_dependency()):
    - LLMRouterCapability             → LLMPort (resolved per AgentSpec.intelligence)
    - LLMRouterCapability             → VLMPort (resolved per AgentSpec.intelligence, if vlm_enabled)
    - MemoryCapability                → MemoryPort
    - RAGCapability                   → RAGPort (ChromaDBRAGPort by default)
    - GraphRAGCapability              → GraphPort (Neo4jGraphPort by default)
    - ToolRegistryCapability          → ToolExecutorPort
    - SandboxCapability               → SandboxPort
    - TokenBudgetCapability           → TokenBudgetPort
    - SecurityCapability              → SecurityPort
    - MessagingCapability             → MessagingContract
    - AgentLifecycleManagerCapability → AgentLifecyclePort
    - ObservabilityCapability         → ObservabilityPort

    Protocols:
    - All inbound messages are HMAC-SHA256 verified before processing.
    - All inbound messages are TTL-checked before processing.
    - All prompts are scanned for injection before LLM call.
    - Token budget is checked before every LLM call.
    - Heartbeat is emitted every 30 seconds.
    - LoopGuard enforces iteration ceiling; raises LoopLimitExceededError.
    - inQ is asyncio.PriorityQueue; CRITICAL (0) messages processed first.
    - outQ is asyncio.PriorityQueue; CRITICAL (0) messages dispatched first.
    - All tool calls go exclusively through MCP 2025-11-25 Streamable HTTP transport.
    - All inter-agent communication uses OctopussyMessage exclusively (no direct calls).
    """

    @abstractmethod
    async def enqueue(self, message: OctopussyMessage) -> None:
        """Enqueue an inbound message into inQ. Priority derived from message.priority."""
        ...

    @abstractmethod
    async def pause(self) -> None: ...

    @abstractmethod
    async def resume(self) -> None: ...

    @abstractmethod
    async def stop(self) -> None: ...

    @abstractmethod
    async def inject_dependency(self) -> None:
        """
        CCA Lifecycle Phase 3: inject all required interface references.
        Injects: LLMPort, VLMPort, MemoryPort, RAGPort, GraphPort,
                 ToolExecutorPort, SandboxPort, TokenBudgetPort,
                 SecurityPort, MessagingContract, AgentLifecyclePort,
                 ObservabilityPort.
        """
        ...


