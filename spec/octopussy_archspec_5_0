from octopussy.core.message import OctopussyMessage


class CommunicationPort(ABC):
    """
    Abstract base for all inter-system communication protocol ports.
    Protocols include both behavioral contracts and wire-level transport standards.
    """
    @abstractmethod
    async def send(self, destination: str, message: OctopussyMessage) -> None:
        """Send a message to the given destination."""
        ...

    @abstractmethod
    async def receive(
        self,
        source: str,
        handler: Callable[[OctopussyMessage], Awaitable[None]],
    ) -> None:
        """Subscribe to messages from source; invoke handler for each received message."""
        ...

    @abstractmethod
    async def connect(self) -> None:
        """Establish the connection to the transport backend."""
        ...

    @abstractmethod
    async def disconnect(self) -> None:
        """Gracefully close the connection to the transport backend."""
        ...


