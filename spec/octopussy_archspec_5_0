# octopussy/core/registry.py

from __future__ import annotations
from collections import defaultdict, deque
from typing import Any


class CircularDependencyError(Exception): ...
class CapabilityRegistrationError(Exception): ...


class OctopussyCapabilityRegistry:
    """
    Authoritative catalogue of all Capability Instances.
    Detects circular dependencies at registration time using Kahn's algorithm.
    Rejects non-Capability registrations.
    Is itself a CCA element.
    """

    def __init__(self) -> None:
        self._instances:    dict[str, Any]        = {}
        self._dependencies: dict[str, list[str]]  = {}

    def register(self, name: str, instance: Any, dependencies: list[str]) -> None:
        """
        Register a Capability Instance.
        Raises CapabilityRegistrationError if instance is not a Capability.
        Raises CircularDependencyError if registration creates a cycle.
        """
        if not hasattr(instance, "initialize") or not hasattr(instance, "inject_dependency"):
            raise CapabilityRegistrationError(
                f"{name} is not a valid Capability (missing initialize/inject_dependency)"
            )
        self._instances[name]    = instance
        self._dependencies[name] = dependencies
        # Validate no cycles after each registration
        self.topological_order()

    def get(self, name: str) -> Any:
        return self._instances[name]

    def topological_order(self) -> list[str]:
        """
        Compute topologically sorted startup order using Kahn's algorithm.
        Raises CircularDependencyError if a cycle is detected.
        """
        in_degree: dict[str, int] = {name: 0 for name in self._instances}
        for name, deps in self._dependencies.items():
            for dep in deps:
                in_degree[name] += 1

        queue: deque[str] = deque(
            name for name, degree in in_degree.items() if degree == 0
        )
        order: list[str] = []

        # Build reverse adjacency: dep → [names that depend on dep]
        dependents: dict[str, list[str]] = defaultdict(list)
        for name, deps in self._dependencies.items():
            for dep in deps:
                dependents[dep].append(name)

        while queue:
            name = queue.popleft()
            order.append(name)
            for dependent in dependents[name]:
                in_degree[dependent] -= 1
                if in_degree[dependent] == 0:
                    queue.append(dependent)

        if len(order) != len(self._instances):
            raise CircularDependencyError(
                "Circular dependency detected among Capabilities: "
                f"{set(self._instances) - set(order)}"
            )
        return order

