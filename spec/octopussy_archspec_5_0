from __future__ import annotations
from abc import ABC, abstractmethod

from octopussy.core.message import OctopussyMessage


class DLQPort(ABC):
    """
    Abstract base for the Dead Letter Queue port.
    Provided by: MessagingCapability.
    Consumed by: OrchestratorCapability (for CLI/REST DLQ management).
    Stores all messages that could not be delivered after the maximum retry attempts.
    All DLQ entries are persisted (SQLite by default) and are never silently discarded.
    """

    @abstractmethod
    async def enqueue_failed(
        self,
        message: OctopussyMessage,
        failure_reason: str,
        attempt_count: int,
    ) -> str:
        """
        Store a failed message in the DLQ.
        Returns a unique dlq_entry_id.
        Called automatically by MessagingCapability after 3 failed delivery attempts.
        """
        ...

    @abstractmethod
    async def list_entries(self, limit: int = 100) -> list[dict]:
        """
        List DLQ entries (most recent first).
        Each entry: dlq_entry_id, message_id, sender_id, recipient_id,
        failure_reason, attempt_count, failed_at (Unix timestamp), payload summary.
        """
        ...

    @abstractmethod
    async def get_entry(self, dlq_entry_id: str) -> dict:
        """Retrieve a single DLQ entry by ID, including the full original message."""
        ...

    @abstractmethod
    async def replay_entry(self, dlq_entry_id: str) -> None:
        """Re-publish the original message. Removes from DLQ on successful re-delivery."""
        ...

    @abstractmethod
    async def discard_entry(self, dlq_entry_id: str) -> None:
        """Permanently discard a DLQ entry (operator decision). Irreversible."""
        ...

    @abstractmethod
    async def get_size(self) -> int:
        """Return the current number of entries in the DLQ."""
        ...

