from __future__ import annotations
import asyncio
from abc import ABC, abstractmethod
from dataclasses import dataclass
from typing import Any
from uuid import UUID

from octopussy.core.enums import AgentState, MessageType
from octopussy.core.message import OctopussyMessage
from octopussy.core.models.agent_spec import AgentSpec
from octopussy.core.ports.ports import (
    AgentLifecyclePort, ObservabilityPort, SecurityPort,
    TokenBudgetPort, ToolExecutorPort, MemoryPort,
)
from octopussy.core.ports.llm_ports import LLMPort, VLMPort
from octopussy.core.ports.rag_ports import RAGPort
from octopussy.core.ports.graph_ports import GraphPort


@dataclass
class AgentContext:
    """
    Runtime context passed to tool executors and MCP clients.
    Intentionally mutable during task execution; not shared between agents.
    """
    agent_id:   UUID
    session_id: UUID
    trace_id:   UUID
    spec:       AgentSpec
    iteration:  int = 0


class OctopussyAgent(ABC):
    """
    Abstract base class for all Octopussy agents.

    Template Method pattern: _message_loop() defines the fixed algorithm.
    Subclasses override process_task() to implement agent-specific behavior.

    All agents:
    - Communicate exclusively via OctopussyMessage (never direct method calls)
    - Never share state with other agents
    - Never block the event loop
    - Verify every inbound message signature before processing
    - Check TTL before processing
    - Check token budget before every LLM call
    - Emit heartbeats every _HEARTBEAT_INTERVAL_SEC seconds
    - Respect LoopGuard iteration ceiling
    - inQ: asyncio.PriorityQueue — CRITICAL (0) processed first
    - outQ: asyncio.PriorityQueue — CRITICAL (0) dispatched first
    """

    _HEARTBEAT_INTERVAL_SEC: int = 30

    def __init__(
        self,
        spec:           AgentSpec,
        hmac_secret:    bytes,
        lifecycle:      AgentLifecyclePort,
        obs:            ObservabilityPort,
        security:       SecurityPort,
        token_budget:   TokenBudgetPort,
        tool_executor:  ToolExecutorPort,
        llm_port:       LLMPort,
        vlm_port:       VLMPort | None       = None,
        rag:            RAGPort | None        = None,
        graph:          GraphPort | None      = None,
        memory:         MemoryPort | None     = None,
    ) -> None:
        if not isinstance(hmac_secret, bytes):
            raise TypeError("hmac_secret must be bytes")
        self._spec          = spec
        self._agent_id      = spec.agent_id
        self._hmac_secret   = hmac_secret
        self._lifecycle     = lifecycle
        self._obs           = obs
        self._security      = security
        self._token_budget  = token_budget
        self._tool_executor = tool_executor
        self._llm_port      = llm_port
        self._vlm_port      = vlm_port
        self._rag           = rag
        self._graph         = graph
        self._memory        = memory

        # inQ: priority inbound queue (asyncio.PriorityQueue)
        # Items are (priority_value: int, message: OctopussyMessage)
        # CRITICAL=0 is dequeued first.
        self._inQ:  asyncio.PriorityQueue[tuple[int, OctopussyMessage]] = asyncio.PriorityQueue()
        # outQ: priority outbound queue (asyncio.PriorityQueue)
        # Items are (priority_value: int, message: OctopussyMessage)
        # CRITICAL=0 is dispatched first.
        self._outQ: asyncio.PriorityQueue[tuple[int, OctopussyMessage]] = asyncio.PriorityQueue()

        self._running:  bool = False
        self._paused:   bool = False
        self._loop_count: int = 0

    async def start(self) -> None:
        """Start all agent loops. Called by OCLM during start() phase."""
        self._running = True
        await self._lifecycle.register_agent(self._agent_id, self._spec.name)
        await self._lifecycle.transition_state(self._agent_id, AgentState.IDLE)
        asyncio.create_task(self._message_loop())
        asyncio.create_task(self._outbound_dispatch_loop())
        asyncio.create_task(self._heartbeat_loop())

    async def enqueue(self, message: OctopussyMessage) -> None:
        """Enqueue an inbound message. Priority derived from message.priority."""
        await self._inQ.put((int(message.priority), message))

    async def pause(self) -> None:
        self._paused = True
        await self._lifecycle.transition_state(self._agent_id, AgentState.PAUSED)

    async def resume(self) -> None:
        self._paused = False
        await self._lifecycle.transition_state(self._agent_id, AgentState.IDLE)

    async def stop(self) -> None:
        self._running = False
        await self._lifecycle.transition_state(self._agent_id, AgentState.STOPPING)

    async def _message_loop(self) -> None:
        """
        Template Method: fixed algorithm for all agents.
        Chain of Responsibility: sig → TTL → control → injection → budget → process
        """
        while self._running:
            if self._paused:
                await asyncio.sleep(0.1)
                continue
            try:
                _, message = await asyncio.wait_for(self._inQ.get(), timeout=1.0)
            except asyncio.TimeoutError:
                continue

            try:
                # Step 1: Verify HMAC-SHA256 signature
                if not message.verify_signature(self._hmac_secret):
                    self._obs.log("WARNING", "Invalid signature; dropping message",
                                  {"message_id": str(message.message_id)})
                    continue

                # Step 2: TTL check
                if message.is_expired():
                    self._obs.log("WARNING", "Expired message; dropping",
                                  {"message_id": str(message.message_id)})
                    continue

                # Step 3: Control messages
                if message.message_type == MessageType.CONTROL:
                    await self._handle_control(message)
                    continue

                # Step 4: Prompt injection scan
                task_text = message.payload.get("task", "")
                if not await self._security.scan_prompt(task_text):
                    self._obs.log("WARNING", "Prompt injection detected; dropping",
                                  {"message_id": str(message.message_id)})
                    continue

                # Step 5: Token budget check
                if not await self._token_budget.check_budget(self._agent_id, "hourly"):
                    self._obs.log("WARNING", "Token budget exhausted; dropping",
                                  {"message_id": str(message.message_id)})
                    continue

                # Step 6: LoopGuard
                self._loop_count += 1
                if self._loop_count > self._spec.permissions.max_iterations:
                    self._obs.log("ERROR", "LoopGuard: iteration ceiling exceeded",
                                  {"agent_id": str(self._agent_id)})
                    await self._lifecycle.transition_state(self._agent_id, AgentState.ERROR)
                    break

                # Step 7: Process
                await self._lifecycle.transition_state(self._agent_id, AgentState.PROCESSING)
                result = await self.process_task(message)
                await self._lifecycle.transition_state(self._agent_id, AgentState.IDLE)

            except Exception as exc:
                self._obs.log("ERROR", f"Agent error: {exc}",
                              {"agent_id": str(self._agent_id), "exc": str(exc)})
                await self._lifecycle.transition_state(self._agent_id, AgentState.ERROR)

    async def _outbound_dispatch_loop(self) -> None:
        """Consume outQ and forward messages to MessagingCapability."""
        while self._running:
            try:
                _, message = await asyncio.wait_for(self._outQ.get(), timeout=1.0)
                await self._dispatch_outbound(message)
            except asyncio.TimeoutError:
                continue

    async def _heartbeat_loop(self) -> None:
        """Emit heartbeat every _HEARTBEAT_INTERVAL_SEC seconds."""
        while self._running:
            await asyncio.sleep(self._HEARTBEAT_INTERVAL_SEC)
            await self._lifecycle.record_heartbeat(self._agent_id)

    async def _handle_control(self, message: OctopussyMessage) -> None:
        """Handle CONTROL messages (pause, resume, stop)."""
        command = message.payload.get("command", "")
        if command == "pause":
            await self.pause()
        elif command == "resume":
            await self.resume()
        elif command == "stop":
            await self.stop()

    @abstractmethod
    async def process_task(self, message: OctopussyMessage) -> Any:
        """Subclasses implement agent-specific task processing logic here."""
        ...

    @abstractmethod
    async def _dispatch_outbound(self, message: OctopussyMessage) -> None:
        """Dispatch a message from outQ via MessagingCapability."""
        ...

