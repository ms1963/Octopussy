from __future__ import annotations
from abc import ABC, abstractmethod
from uuid import UUID

from octopussy.core.models.agent_spec import AgentHandle, AgentInfo, TaskHandle, TeamHandle


class OrchestratorContract(ABC):
    """
    Provisions (interfaces this Capability provides to others):
    - submit_task: submit a task to the best available agent
    - submit_team_task: submit a task to a team
    - create_agent: create a new agent from a config directory
    - create_team: create a new team from a team spec
    - get_agent_info: retrieve agent status and metadata
    - list_agents: list all running agents
    - get_task_result: retrieve the result of a submitted task
    - get_system_status: retrieve system-wide health and metrics
    - render_agent_graph: render the agent graph in the requested format

    Requirements (interfaces this Capability consumes, injected via inject_dependency()):
    - AgentFactoryCapability          → AgentFactoryContract
    - AgentLifecycleManagerCapability → AgentLifecyclePort
    - TeamCapability                  → TeamContract
    - MessagingCapability             → MessagingContract
    - SecurityCapability              → SecurityPort
    - ObservabilityCapability         → ObservabilityPort

    Protocols:
    - REST API served on port 47200 over HTTPS (TLS).
    - All REST endpoints require JWT authentication (SecurityCapability.authenticate()).
    - RBAC enforced on all endpoints (SecurityCapability.authorize()).
    - All task submissions result in a TaskHandle for async result retrieval.
    - submit_task() selects the best available agent via TaskRouter.
    - get_system_status() aggregates health from all registered Capabilities.
    """

    @abstractmethod
    async def submit_task(
        self, task: str, agent_id: UUID | None = None, priority: str = "NORMAL"
    ) -> TaskHandle: ...

    @abstractmethod
    async def submit_team_task(
        self, team_id: UUID, task: str, priority: str = "NORMAL"
    ) -> TaskHandle: ...

    @abstractmethod
    async def create_agent(self, config_dir: str) -> AgentHandle: ...

    @abstractmethod
    async def create_team(self, team_config_dir: str) -> TeamHandle: ...

    @abstractmethod
    async def get_agent_info(self, agent_id: UUID) -> AgentInfo: ...

    @abstractmethod
    async def list_agents(self) -> list[AgentInfo]: ...

    @abstractmethod
    async def get_task_result(self, task_id: UUID) -> dict: ...

    @abstractmethod
    async def get_system_status(self) -> dict: ...

    @abstractmethod
    async def render_agent_graph(self, fmt: str = "dot") -> str: ...

    @abstractmethod
    async def inject_dependency(self) -> None:
        """
        CCA Lifecycle Phase 3: inject all required interface references.
        Injects: AgentFactoryContract, AgentLifecyclePort, TeamContract,
                 MessagingContract, SecurityPort, ObservabilityPort.
        """
        ...


