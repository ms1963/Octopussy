4.0.2 OctopussyMessage
# octopussy/core/message.py

from __future__ import annotations
import hmac
import hashlib
import time
from dataclasses import dataclass
from uuid import UUID, uuid4

from octopussy.core.enums import MessagePriority, MessageType


@dataclass(frozen=True, slots=True)
class OctopussyMessage:
    """
    Immutable inter-agent message. All inter-agent communication uses this type exclusively.
    Signature is mandatory (bytes, never Optional[bytes]).
    payload must be a dict of JSON-serializable values only.
    """
    message_id:   UUID
    sender_id:    UUID
    recipient_id: UUID
    message_type: MessageType
    payload:      dict          # JSON-serializable values only; validated at create()
    priority:     MessagePriority
    trace_id:     UUID
    created_at:   float         # Unix timestamp (UTC)
    ttl_seconds:  int
    signature:    bytes         # HMAC-SHA256; mandatory; never Optional

    @staticmethod
    def create(
        sender_id:    UUID,
        recipient_id: UUID,
        message_type: MessageType,
        payload:      dict,
        secret:       bytes,
        trace_id:     UUID | None = None,
        priority:     MessagePriority = MessagePriority.NORMAL,
        ttl_seconds:  int = 300,
    ) -> "OctopussyMessage":
        """
        Factory method. Signs the message with HMAC-SHA256.
        secret must be bytes (never str, never None).
        payload must contain only JSON-serializable values.
        """
        if not isinstance(secret, bytes):
            raise TypeError("secret must be bytes")
        message_id = uuid4()
        trace_id   = trace_id or uuid4()
        created_at = time.time()
        sig_data = (
            f"{message_id}{sender_id}{recipient_id}{message_type}"
            f"{created_at}{ttl_seconds}{priority}"
        ).encode("utf-8")
        signature = hmac.new(secret, sig_data, hashlib.sha256).digest()
        return OctopussyMessage(
            message_id   = message_id,
            sender_id    = sender_id,
            recipient_id = recipient_id,
            message_type = message_type,
            payload      = payload,
            priority     = priority,
            trace_id     = trace_id,
            created_at   = created_at,
            ttl_seconds  = ttl_seconds,
            signature    = signature,
        )

    def verify_signature(self, secret: bytes) -> bool:
        """
        Constant-time HMAC-SHA256 verification.
        secret must be bytes (never str, never None).
        Returns False (never raises) so callers can log-and-drop.
        """
        if not isinstance(secret, bytes):
            return False
        sig_data = (
            f"{self.message_id}{self.sender_id}{self.recipient_id}"
            f"{self.message_type}{self.created_at}{self.ttl_seconds}{self.priority}"
        ).encode("utf-8")
        expected = hmac.new(secret, sig_data, hashlib.sha256).digest()
        return hmac.compare_digest(self.signature, expected)

    def is_expired(self) -> bool:
        return time.time() > self.created_at + self.ttl_seconds

